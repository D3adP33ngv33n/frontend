@page "/blog"

<PageTitle>Blog - NOSTDLIB</PageTitle>

<Navbar />

<section class="blog">
    <div class="container">
        <div class="section-header text-center">
            <h1>Blog</h1>
            <p class="section-subtitle">Research, tools, and technical write-ups</p>
        </div>

        <div class="blog-grid">
            @foreach (var post in BlogPosts)
            {
                <article class="blog-card">
                    <div class="blog-icon">@post.Icon</div>
                    <h3>@post.Title</h3>
                    <p class="blog-purpose">@post.Purpose</p>

                    <div class="blog-features">
                        <h4>Key Features</h4>
                        <ul>
                            @foreach (var feature in post.Features)
                            {
                                <li>@feature</li>
                            }
                        </ul>
                    </div>

                    <div class="blog-meta">
                        <span class="blog-tech mono">@post.Technologies</span>
                        <span class="blog-status @post.Status.ToLower()">@post.Status</span>
                    </div>

                    <p class="blog-audience"><strong>Audience:</strong> @post.Audience</p>

                    <div class="blog-links">
                        @if (post.Url.StartsWith("/"))
                        {
                            <a href="@post.Url" class="btn btn-primary">
                                Read More
                            </a>
                        }
                        else
                        {
                            <a href="@post.Url" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                                Read More
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(post.GitHubUrl))
                        {
                            <a href="@post.GitHubUrl" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                                GitHub
                            </a>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<Footer />


@page "/Error"
@inject ILocalizationService L
@implements IDisposable

<PageTitle>@L["Error.Title"]</PageTitle>

<section class="error-page">
    <div class="container">
        <div class="error-content">
            <span class="error-symbol">⚠</span>
            <h1>@L["Error.Title"]</h1>
            <p>@L["Error.Message"]</p>
            <a href="/" class="btn btn-primary">@L["Error.ReturnHome"]</a>
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}

<style>
    .error-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-content {
        text-align: center;
    }

    .error-symbol {
        font-size: 4rem;
        color: var(--primary-color);
        display: block;
        margin-bottom: 1rem;
    }
</style>

[
  {
    "id": 1,
    "code": "SEC-01",
    "title": "\u0531\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0561\u0562\u0561\u0576",
    "level": "\u0531\u057e\u0561\u0563",
    "location": "\u0535\u0580\u0587\u0561\u0576, \u0540\u0561\u0575\u0561\u057d\u057f\u0561\u0576",
    "type": "\u053c\u056b\u0561\u0580\u056a\u0565\u0584 \u0564\u0580\u0578\u0582\u0575\u0569",
    "description": "\u0531\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0574\u0578\u0576\u056b\u057f\u0578\u0580\u056b\u0576\u0563\u056b, \u0574\u056b\u057b\u0561\u0564\u0565\u057a\u0565\u0580\u056b \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0561\u0576 \u0587 \u057d\u057a\u0561\u057c\u0576\u0561\u056c\u056b\u0584\u0576\u0565\u0580\u056b\u0576 \u0561\u0580\u0561\u0563\u0561\u0576\u0584\u056b \u0563\u0578\u0580\u056e\u0578\u0572\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0572\u0565\u056f\u0561\u057e\u0561\u0580\u0578\u0582\u0574\u0589 \u0531\u0577\u056d\u0561\u057f\u0561\u0576\u0584 \u0561\u057c\u0561\u057b\u0561\u057f\u0561\u0580 \u0570\u0561\u0575\u057f\u0576\u0561\u0562\u0565\u0580\u0574\u0561\u0576 \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0565\u0580\u0578\u057e\u055d \u057a\u0561\u0577\u057f\u057a\u0561\u0576\u0565\u056c\u0578\u0582 \u0570\u0561\u0573\u0561\u056d\u0578\u0580\u0564\u056b \u056f\u0580\u056b\u057f\u056b\u056f\u0561\u056f\u0561\u0576 \u0565\u0576\u0569\u0561\u056f\u0561\u057c\u0578\u0582\u0581\u057e\u0561\u056e\u0584\u0568 \u0562\u0561\u0580\u0564 \u0570\u0561\u056f\u0561\u057c\u0561\u056f\u0578\u0580\u0564\u0576\u0565\u0580\u056b\u0581\u0589",
    "requirements": [
      "5+ \u057f\u0561\u0580\u057e\u0561 \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0563\u0578\u0580\u056e\u0578\u0572\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u0578\u0582\u0574 \u056f\u0561\u0574 \u0574\u056b\u057b\u0561\u0564\u0565\u057a\u0565\u0580\u056b\u0576 \u0561\u0580\u0561\u0563\u0561\u0576\u0584\u0578\u0582\u0574",
      "\u053d\u0578\u0580\u0568 \u0583\u0578\u0580\u0571\u0561\u0572\u056b\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576 SIEM \u0570\u0561\u0580\u0569\u0561\u056f\u0576\u0565\u0580\u0578\u0582\u0574 \u0587 \u057d\u057a\u0561\u057c\u0576\u0561\u056c\u056b\u0584\u0576\u0565\u0580\u056b \u0578\u0580\u0578\u0576\u0574\u0561\u0576 \u0574\u0565\u0569\u0578\u0564\u0578\u056c\u0578\u0563\u056b\u0561\u0576\u0565\u0580\u0578\u0582\u0574",
      "\u0531\u057a\u0561\u0581\u0578\u0582\u0581\u057e\u0561\u056e \u0583\u0578\u0580\u0571 APT \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0561\u0576 \u0587 \u0561\u057f\u0580\u056b\u0562\u0578\u0582\u0581\u056b\u0561\u0575\u056b \u0574\u0565\u057b",
      "CISSP, GCIA \u056f\u0561\u0574 \u0570\u0561\u0574\u0561\u0580\u056a\u0565\u0584 \u057d\u0565\u0580\u057f\u056b\u0586\u056b\u056f\u0561\u0581\u056b\u0561",
      "\u0533\u0561\u0572\u057f\u0576\u056b \u0576\u057e\u056b\u0580\u0561\u0570\u0561\u057d\u057f\u0561\u057f\u0578\u0582\u0574 \u057d\u057f\u0561\u0576\u0561\u056c\u0578\u0582 \u0570\u0576\u0561\u0580\u0561\u057e\u0578\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576"
    ]
  },
  {
    "id": 2,
    "code": "SEC-02",
    "title": "\u0539\u0561\u0583\u0561\u0576\u0581\u0574\u0561\u0576 \u0569\u0565\u057d\u057f\u0561\u057e\u0578\u0580\u0578\u0572",
    "level": "\u0531\u057e\u0561\u0563",
    "location": "\u0535\u0580\u0587\u0561\u0576, \u0540\u0561\u0575\u0561\u057d\u057f\u0561\u0576",
    "type": "\u053c\u056b\u0561\u0580\u056a\u0565\u0584 \u0564\u0580\u0578\u0582\u0575\u0569",
    "description": "\u054f\u0561\u0580\u0562\u0565\u0580 \u0574\u056b\u057b\u0561\u057e\u0561\u0575\u0580\u0565\u0580\u0578\u0582\u0574 \u0569\u0578\u0582\u0575\u056c\u0561\u057f\u0580\u057e\u0561\u056e \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0563\u0576\u0561\u0570\u0561\u057f\u0578\u0582\u0574\u0576\u0565\u0580\u056b \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u0578\u0582\u0574\u0589 \u0541\u0561\u0576\u0581\u0565\u0580\u0578\u0582\u0574, \u0570\u0561\u057e\u0565\u056c\u057e\u0561\u056e\u0576\u0565\u0580\u0578\u0582\u0574 \u0587 \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0565\u0580\u0578\u0582\u0574 \u056d\u0578\u0581\u0565\u056c\u056b\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0570\u0561\u0575\u057f\u0576\u0561\u0562\u0565\u0580\u0578\u0582\u0574 \u0574\u0561\u0576\u0580\u0561\u0574\u0561\u057d\u0576 \u057e\u0565\u0580\u0561\u0581\u0574\u0561\u0576 \u0578\u0582\u0572\u0565\u0581\u0578\u0582\u0575\u0581\u0576\u0565\u0580\u0578\u057e\u0589",
    "requirements": [
      "3+ \u057f\u0561\u0580\u057e\u0561 \u057a\u0580\u0578\u0586\u0565\u057d\u056b\u0578\u0576\u0561\u056c \u0569\u0561\u0583\u0561\u0576\u0581\u0574\u0561\u0576 \u0569\u0565\u057d\u057f\u0565\u0580\u056b \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u0574\u0561\u0576",
      "\u0553\u0578\u0580\u0571\u0561\u0572\u056b\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576 \u0571\u0565\u057c\u0584\u0578\u057e \u0577\u0561\u0570\u0561\u0563\u0578\u0580\u056e\u0574\u0561\u0576 \u0587 \u057d\u0565\u0583\u0561\u056f\u0561\u0576 \u0563\u0578\u0580\u056e\u056b\u0584\u0576\u0565\u0580\u056b \u0574\u0577\u0561\u056f\u0574\u0561\u0576 \u0574\u0565\u057b",
      "\u0553\u0578\u0580\u0571 \u057e\u0565\u0562, \u0581\u0561\u0576\u0581\u0561\u0575\u056b\u0576, \u0561\u0574\u057a\u0561\u0575\u056b\u0576 \u0587 \u0562\u057b\u057b\u0561\u0575\u056b\u0576 \u0570\u0561\u0580\u0571\u0561\u056f\u0574\u0561\u0576 \u0574\u0561\u056f\u0565\u0580\u0565\u057d\u0576\u0565\u0580\u0578\u0582\u0574",
      "OSCP, OSCE \u056f\u0561\u0574 \u0570\u0561\u0574\u0561\u0580\u056a\u0565\u0584 \u0561\u057a\u0561\u0581\u0578\u0582\u0581\u057e\u0561\u056e \u056f\u0561\u0580\u0578\u0572\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580",
      "\u054f\u0565\u056d\u0576\u056b\u056f\u0561\u056f\u0561\u0576 \u0570\u0561\u0572\u0578\u0580\u0564\u0561\u056f\u0581\u0574\u0561\u0576 \u0587 \u0570\u0561\u0577\u057e\u0565\u057f\u057e\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u056f\u0561\u0566\u0574\u0574\u0561\u0576 \u0570\u0574\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580"
    ]
  },
  {
    "id": 3,
    "code": "SEC-03",
    "title": "\u0533\u0561\u0572\u057f\u0576\u0561\u0563\u0580\u0561\u056f\u0561\u0576 \u0570\u0565\u057f\u0561\u0566\u0578\u057f\u0578\u0572",
    "level": "\u0531\u057e\u0561\u0563",
    "location": "\u0535\u0580\u0587\u0561\u0576, \u0540\u0561\u0575\u0561\u057d\u057f\u0561\u0576",
    "type": "\u053c\u056b\u0561\u0580\u056a\u0565\u0584 \u0564\u0580\u0578\u0582\u0575\u0569",
    "description": "\u0544\u0565\u0580 \u0563\u0561\u0572\u057f\u0576\u0561\u0563\u0580\u0561\u056f\u0561\u0576 \u056f\u0561\u0580\u0578\u0572\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0566\u0561\u0580\u0563\u0561\u0581\u0578\u0582\u0574 \u0562\u0576\u0585\u0580\u056b\u0576\u0561\u056f \u0570\u0565\u057f\u0561\u0566\u0578\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0587 \u056b\u0580\u0561\u056f\u0561\u0576\u0561\u0581\u0574\u0561\u0576 \u057e\u0565\u0580\u056c\u0578\u0582\u056e\u0578\u0582\u0569\u0575\u0561\u0576 \u0574\u056b\u057b\u0578\u0581\u0578\u057e\u0589 \u0533\u0561\u0572\u057f\u0576\u0561\u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0565\u0580\u056b \u0563\u0576\u0561\u0570\u0561\u057f\u0578\u0582\u0574, \u0569\u0578\u0582\u0575\u056c \u056f\u0578\u0572\u0574\u0565\u0580\u056b \u0570\u0561\u0575\u057f\u0576\u0561\u0562\u0565\u0580\u0578\u0582\u0574 \u0587 \u0561\u0576\u057e\u057f\u0561\u0576\u0563 \u056f\u0561\u057a\u056b \u0576\u0578\u0580 \u0574\u0578\u057f\u0565\u0581\u0578\u0582\u0574\u0576\u0565\u0580\u056b \u0574\u0577\u0561\u056f\u0578\u0582\u0574\u0589",
    "requirements": [
      "\u0533\u056b\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0569\u0565\u056f\u0576\u0561\u056e\u0578\u0582 \u0561\u057d\u057f\u056b\u0573\u0561\u0576 \u0563\u0561\u0572\u057f\u0576\u0561\u0563\u0580\u0578\u0582\u0569\u0575\u0561\u0576, \u0574\u0561\u0569\u0565\u0574\u0561\u057f\u056b\u056f\u0561\u0575\u056b \u056f\u0561\u0574 \u0570\u0561\u0574\u0561\u0580\u056a\u0565\u0584 \u0570\u0565\u057f\u0561\u0566\u0578\u057f\u0561\u056f\u0561\u0576 \u0583\u0578\u0580\u0571\u0578\u0582\u0574",
      "\u0540\u0580\u0561\u057a\u0561\u0580\u0561\u056f\u057e\u0561\u056e \u0561\u0577\u056d\u0561\u057f\u0561\u0576\u0584\u0576\u0565\u0580 \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0580\u0565\u0581\u0565\u0576\u0566\u0561\u057e\u0578\u0580\u057e\u0561\u056e \u0570\u0561\u0576\u0564\u0565\u057d\u0576\u0565\u0580\u0578\u0582\u0574",
      "\u0553\u0578\u0580\u0571\u0561\u0572\u056b\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576 \u057a\u0578\u057d\u057f-\u0584\u057e\u0561\u0576\u057f\u0561\u0575\u056b\u0576 \u0563\u0561\u0572\u057f\u0576\u0561\u0563\u0580\u0561\u056f\u0561\u0576 \u057d\u056d\u0565\u0574\u0561\u0576\u0565\u0580\u0578\u0582\u0574",
      "\u0556\u0578\u0580\u0574\u0561\u056c \u057d\u057f\u0578\u0582\u0563\u0574\u0561\u0576 \u0587 \u0561\u057a\u0561\u0581\u0578\u0582\u0575\u0581\u0576\u0565\u0580\u056b \u0570\u0561\u0574\u0561\u056f\u0561\u0580\u0563\u0565\u0580\u0578\u0582\u0574 \u0570\u0574\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576",
      "\u0533\u0561\u0572\u057f\u0576\u056b \u0570\u0565\u057f\u0561\u0566\u0578\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0570\u0561\u0574\u0561\u0580 \u0576\u057e\u056b\u0580\u0561\u0570\u0561\u057d\u057f\u0561\u057f\u0578\u0582\u0574 \u057d\u057f\u0561\u0576\u0561\u056c\u0578\u0582 \u0570\u0576\u0561\u0580\u0561\u057e\u0578\u0580\u0578\u0582\u0569\u0575\u0578\u0582\u0576"
    ]
  },
  {
    "id": 4,
    "code": "SEC-04",
    "title": "DevSecOps \u056b\u0576\u056a\u0565\u0576\u0565\u0580",
    "level": "\u0531\u057e\u0561\u0563",
    "location": "\u0535\u0580\u0587\u0561\u0576, \u0540\u0561\u0575\u0561\u057d\u057f\u0561\u0576",
    "type": "\u053c\u056b\u0561\u0580\u056a\u0565\u0584 \u0564\u0580\u0578\u0582\u0575\u0569",
    "description": "\u0531\u0576\u057e\u057f\u0561\u0576\u0563 CI/CD \u0583\u0561\u0575\u0583\u056c\u0561\u0575\u0576\u0576\u0565\u0580\u056b \u0576\u0561\u056d\u0561\u0563\u056e\u0578\u0582\u0574 \u0587 \u057d\u057a\u0561\u057d\u0561\u0580\u056f\u0578\u0582\u0574 \u056b\u0576\u057f\u0565\u0563\u0580\u057e\u0561\u056e \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u056f\u0561\u057c\u0561\u057e\u0561\u0580\u0574\u0561\u0576 \u0574\u056b\u057b\u0578\u0581\u0576\u0565\u0580\u0578\u057e\u0589 IaC-\u056b \u0576\u0565\u0580\u0564\u0580\u0578\u0582\u0574 \u0578\u0582\u056a\u0565\u0572\u0561\u0581\u057e\u0561\u056e \u056f\u0578\u0576\u0586\u056b\u0563\u0578\u0582\u0580\u0561\u0581\u056b\u0561\u0576\u0565\u0580\u0578\u057e \u0587 \u056d\u0578\u0581\u0565\u056c\u056b\u0578\u0582\u0569\u0575\u0578\u0582\u0576\u0576\u0565\u0580\u056b \u0561\u057e\u057f\u0578\u0574\u0561\u057f \u057d\u056f\u0561\u0576\u0561\u057e\u0578\u0580\u0574\u0561\u0574\u0562 \u0574\u0577\u0561\u056f\u0574\u0561\u0576 \u0578\u0572\u057b \u0581\u056b\u056f\u056c\u0578\u0582\u0574\u0589",
    "requirements": [
      "4+ \u057f\u0561\u0580\u057e\u0561 DevOps \u0578\u056c\u0578\u0580\u057f\u0578\u0582\u0574 \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0578\u0582\u056a\u0565\u0572 \u0577\u0565\u0577\u057f\u0578\u057e",
      "\u053f\u0578\u0576\u057f\u0565\u0575\u0576\u0565\u0580\u0576\u0565\u0580\u056b \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 (Docker, Kubernetes) \u0587 \u0585\u0580\u056f\u0565\u057d\u057f\u0580\u0561\u0581\u056b\u0561\u0575\u056b \u0578\u0582\u056a\u0565\u0572\u0561\u0581\u0574\u0561\u0576 \u0583\u0578\u0580\u0571\u0561\u0572\u056b\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576",
      "IaC \u0563\u0578\u0580\u056e\u056b\u0584\u0576\u0565\u0580\u056b (Terraform, Ansible) \u0587 \u0561\u0576\u057e\u057f\u0561\u0576\u0563\u0578\u0582\u0569\u0575\u0561\u0576 \u0561\u057e\u057f\u0578\u0574\u0561\u057f\u0561\u0581\u0574\u0561\u0576 \u0570\u0574\u057f\u0578\u0582\u0569\u0575\u0578\u0582\u0576",
      "SAST, DAST \u0587 SCA \u0583\u0561\u0575\u0583\u056c\u0561\u0575\u0576\u0576\u0565\u0580\u0578\u0582\u0574 \u0576\u0565\u0580\u0564\u0580\u0574\u0561\u0576 \u0583\u0578\u0580\u0571",

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Blazor WASM (no debug)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "blazor-serve",
      "url": "http://localhost:5090",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Blazor WASM Debug (Edge)",
      "type": "blazorwasm",
      "request": "launch",
      "url": "http://localhost:5090"
    },
    {
      "name": "Blazor WASM Debug (Chrome)",
      "type": "blazorwasm",
      "request": "launch",
      "browser": "chrome",
      "url": "http://localhost:5090"
    }
  ]
}

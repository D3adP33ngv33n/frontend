{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch and Debug Blazor WASM (Edge)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "blazor-serve",
      "url": "http://localhost:5090",
      "webRoot": "${workspaceFolder}",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}"
    },
    {
      "name": "Launch and Debug Blazor WASM (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "blazor-serve",
      "url": "http://localhost:5090",
      "webRoot": "${workspaceFolder}",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}"
    }
  ]
}

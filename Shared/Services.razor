@inject IDataService DataService

<section class="services" id="services">
    <div class="container">
        <div class="section-header text-center">
            <h2>Services</h2>
            <p class="section-subtitle">Comprehensive cybersecurity solutions tailored to your organization</p>
        </div>

        <div class="services-grid">
            @foreach (var service in ServicesList)
            {
                <div class="service-card">
                    <div class="service-icon">
                        @service.Icon
                    </div>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                </div>
            }
        </div>

        <div class="services-note">
            <p class="mono">All engagements are conducted under strict confidentiality agreements. We work directly with
                clients to
                develop customized solutions that address their specific security requirements and threat landscape.</p>
        </div>
    </div>
</section>

@code {
    private List<ServiceItem> ServicesList = new();

    protected override async Task OnInitializedAsync()
    {
        ServicesList = await DataService.GetServicesAsync();
    }
}
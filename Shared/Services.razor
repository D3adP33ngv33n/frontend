@inject IDataService DataService

<section class="services" id="services">
    <div class="container">
        <div class="section-header text-center">
            <h2>Services</h2>
            <p class="section-subtitle">Specialized capabilities for complex security challenges</p>
        </div>

        <Slider Items="ServicesList" TItem="ServiceItem">
            <ItemTemplate Context="service">
                <div class="service-card">
                    <div class="service-icon">
                        @service.Icon
                    </div>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                </div>
            </ItemTemplate>
        </Slider>

        <div class="services-note">
            <p class="mono">Every engagement operates under strict NDA. We collaborate directly with stakeholders to design
                solutions calibrated to your specific threat model and operational requirements.</p>
        </div>
    </div>
</section>

@code {
    private List<ServiceItem> ServicesList = new();

    protected override async Task OnInitializedAsync()
    {
        ServicesList = await DataService.GetServicesAsync();
    }
}

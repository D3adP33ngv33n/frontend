<section class="services" id="services">
    <div class="container">
        <div class="section-header text-center">
            <h2>Services</h2>
            <p class="section-subtitle">Private cybersecurity solutions - by invitation only</p>
        </div>

        <div class="services-grid">
            @foreach (var service in ServicesList)
            {
                <div class="service-card">
                    <div class="service-icon">
                        @service.Icon
                    </div>
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                </div>
            }
        </div>

        <div class="services-note">
            <p><strong>Private Services</strong></p>
            <p>All services are confidential and available exclusively through direct engagement. We do not advertise rates or take public inquiries. Contact is established through trusted referrals only.</p>
        </div>
    </div>
</section>

@code {
    private record ServiceItem(string Title, string Description, string Icon);

    private List<ServiceItem> ServicesList = new()
    {
        new("Security Assessments", "Comprehensive penetration testing and vulnerability analysis for your infrastructure. Identifying weaknesses before adversaries do.", "🔍"),
        new("Incident Response", "Rapid containment and forensic analysis when breaches occur. Discreet handling with full confidentiality.", "🛡️"),
        new("Threat Intelligence", "Proactive monitoring of threat landscapes relevant to your organization. Early warning systems for emerging risks.", "📡"),
        new("Secure Architecture", "Designing resilient systems from the ground up. Defense-in-depth strategies tailored to your threat model.", "🏗️"),
        new("Red Team Operations", "Adversarial simulation to test your defenses under realistic conditions. Full-scope engagements with detailed reporting.", "⚔️"),
        new("Data Protection", "Encryption implementation, secure communications, and data handling protocols. Keeping sensitive information confidential.", "🔐")
    };
}

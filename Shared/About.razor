<section class="about" id="about">
    <div class="container">
        <div class="section-header">
            <h2>About Us</h2>
            <p class="section-subtitle">Where expertise meets confidentiality</p>
        </div>

        <div class="about-content">
            <div class="about-text">
                <p class="mono">
                    Our team comprises seasoned security professionals with deep expertise across offensive and defensive domains.
                    We prioritize capability and results over visibility.
                </p>
                <p>
                    We deliver enterprise cybersecurity solutions, integrating advanced technologies and cryptographic systems,
                    designed for environments where precision, resilience, and confidentiality are essential.
                </p>
                <p>
                    No publicity. No exposure.
                </p>
                <p>
                    Only results.
                </p>
                <div class="principles">
                    <h3>Principles</h3>
                    <ul class="principles-list">
                        @foreach (var principle in Principles)
                        {
                            <li class="principle-item mono">
                                <span class="principle-marker">◉</span>
                                @principle
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<string> Principles = new()
{
"Defense in depth is our foundation",
"Client confidentiality is paramount",
"We operate on a need-to-know basis",
"Trust is earned through results"
};

    private List<List<string>> DataStream = new();

    protected override void OnInitialized()
    {
        GenerateDataStream();
    }

    private void GenerateDataStream()
    {
        var random = new Random();
        DataStream = new List<List<string>>();
        for (int i = 0; i < 10; i++)
        {
            var line = new List<string>();
            for (int j = 0; j < 10; j++)
            {
                line.Add(random.Next(2).ToString());
            }
            DataStream.Add(line);
        }
    }
}
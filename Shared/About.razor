@inject ILocalizationService L
@implements IDisposable

<section class="about" id="about">
    <div class="container">
        <div class="section-header">
            <h2>@L["About.Title"]</h2>
            <p class="section-subtitle">Precision security for high-stakes environments</p>
        </div>

        <div class="about-content">
            <div class="about-text">
                <p class="mono">
                    Our team brings decades of combined experience across offensive security, cryptographic research, and incident response.
                    We operate where capability matters more than visibility.
                </p>
                <p>
                    We architect and defend systems for organizations facing sophisticated threats—integrating advanced cryptographic protocols
                    and security frameworks built for resilience under pressure.
                </p>
                <p>
                    No case studies. No testimonials.
                </p>
                <p>
                    Just outcomes.
                </p>
                <div class="principles">
                    <h3>Principles</h3>
                    <ul class="principles-list">
                        @foreach (var principle in Principles)
                        {
                            <li class="principle-item mono">
                                <span class="principle-marker">◉</span>
                                @principle
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<string> Principles => new()
    {
        L["About.Principle1"],
        L["About.Principle2"],
        L["About.Principle3"],
        L["About.Principle4"],
        L["About.Principle5"]
    };

    private List<List<string>> DataStream = new();

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
        GenerateDataStream();
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void GenerateDataStream()
    {
        var random = new Random();
        DataStream = new List<List<string>>();
        for (int i = 0; i < 10; i++)
        {
            var line = new List<string>();
            for (int j = 0; j < 10; j++)
            {
                line.Add(random.Next(2).ToString());
            }
            DataStream.Add(line);
        }
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}
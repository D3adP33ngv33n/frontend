<section class="about" id="about">
    <div class="container">
        <div class="section-header">
            <h2>About Us</h2>
            <p class="section-subtitle">We exist where security meets discretion</p>
        </div>

        <div class="about-content">
            <div class="about-text">
                <p class="mono">
                    Our team is composed of specialists who choose anonymity by design. This is not secrecy for its own sake, but a principle: identities are irrelevant; capability is everything.
                </p>
                <p>
                    We deliver private cybersecurity solutions, integrating AI and cryptographic systems, designed for environments where precision, resilience, and confidentiality are non-negotiable.
                </p>
                <p>
                    No publicity. No exposure.
                </p>
                <p>
                    Only results.
                </p>
                <div class="principles">
                    <h3>Principles</h3>
                    <ul class="principles-list">
                        @foreach (var principle in Principles)
                        {
                            <li class="principle-item mono">
                                <span class="principle-marker">◉</span>
                                @principle
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="about-visual">
                <div class="visual-container">
                    <div class="data-stream">
                        @foreach (var line in DataStream)
                        {
                            <div class="stream-line">
                                @foreach (var bit in line)
                                {
                                    <div class="stream-bit">@bit</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<string> Principles = new()
    {
        "We believe in security through obscurity",
        "Our identities remain protected",
        "We operate on a need-to-know basis",
        "Trust is earned, not given"
    };

    private List<List<string>> DataStream = new();

    protected override void OnInitialized()
    {
        GenerateDataStream();
    }

    private void GenerateDataStream()
    {
        var random = new Random();
        DataStream = new List<List<string>>();
        for (int i = 0; i < 10; i++)
        {
            var line = new List<string>();
            for (int j = 0; j < 10; j++)
            {
                line.Add(random.Next(2).ToString());
            }
            DataStream.Add(line);
        }
    }
}

@inject IDataService DataService
@inject ILocalizationService L
@implements IDisposable

<section class="contact" id="contact">
    <div class="container">
        <div class="contact-split">
            <div class="contact-info">
                <h2>@L["Contact.Title"]</h2>
                <p class="contact-description">@L["Contact.Subtitle"]</p>
                <p class="contact-cta mono">@L["Contact.Note"]</p>
            </div>

            <div class="contact-links">
                @foreach (var link in SocialLinks)
                {
                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="contact-card">
                        <div class="contact-card-icon">
                            @if (link.IconType == "linkedin")
                            {
                                <LinkedInIcon />
                            }
                            else if (link.IconType == "github")
                            {
                                <GitHubIcon />
                            }
                        </div>
                        <div class="contact-card-content">
                            <h3>@link.Name</h3>
                            <p>@link.Description</p>
                        </div>
                        <span class="contact-card-arrow">
                            <ArrowIcon />
                        </span>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private List<SocialLink> SocialLinks = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += OnLanguageChanged;
        SocialLinks = await DataService.GetSocialLinksAsync();
    }

    private async void OnLanguageChanged()
    {
        SocialLinks = await DataService.GetSocialLinksAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}

@inject IDataService DataService

<section class="contact" id="contact">
    <div class="container">
        <div class="contact-split">
            <div class="contact-info">
                <h2>Initiate Contact</h2>
                <p class="contact-description">Ready to discuss your security posture? Reach out through a secure channel below.</p>
                <p class="contact-cta mono">All initial communications are treated as confidential</p>
            </div>

            <div class="contact-links">
                @foreach (var link in SocialLinks)
                {
                    <a href="@link.Url" target="_blank" rel="noopener noreferrer" class="contact-card">
                        <div class="contact-card-icon">
                            @if (link.IconType == "linkedin")
                            {
                                <LinkedInIcon />
                            }
                            else if (link.IconType == "github")
                            {
                                <GitHubIcon />
                            }
                        </div>
                        <div class="contact-card-content">
                            <h3>@link.Name</h3>
                            <p>@link.Description</p>
                        </div>
                        <span class="contact-card-arrow">
                            <ArrowIcon />
                        </span>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

@code {
    private List<SocialLink> SocialLinks = new();

    protected override async Task OnInitializedAsync()
    {
        SocialLinks = await DataService.GetSocialLinksAsync();
    }
}

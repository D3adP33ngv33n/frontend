@inject NavigationManager Navigation
@inject IDataService DataService

<section class="careers" id="careers">
    <div class="container">
        <div class="section-header">
            <h2>Careers</h2>
            <p class="section-subtitle">Build your career at the edge of security research</p>
        </div>

        <Slider Items="CurrentOpenings" TItem="JobPosition">
            <ItemTemplate Context="opening">
                <div class="opening-card">
                    <div class="card-header">
                        <div class="opening-code mono">@opening.Code</div>
                        <div class="opening-type">@opening.Type</div>
                    </div>

                    <div class="card-body">
                        <h3 class="opening-title">@opening.Title</h3>

                        <div class="opening-meta">
                            <div class="meta-item">
                                <span class="meta-icon">📊</span>
                                <span class="meta-text">@opening.Level</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-icon">📍</span>
                                <span class="meta-text mono">@opening.Location</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <button class="btn btn-primary" @onclick="() => ViewDetails(opening.Id)">
                            View Details
                        </button>
                    </div>
                </div>
            </ItemTemplate>
        </Slider>

        <div class="careers-note">
            <p class="mono">
                Our selection process is rigorous by design. Qualified candidates receive direct outreach for initial conversations.
            </p>
        </div>
    </div>
</section>

@code {
    private List<JobPosition> CurrentOpenings = new();

    protected override async Task OnInitializedAsync()
    {
        CurrentOpenings = await DataService.GetJobPositionsAsync();
    }

    private void ViewDetails(int jobId)
    {
        Navigation.NavigateTo(Routes.GetCareerDetailsUrl(jobId));
    }
}

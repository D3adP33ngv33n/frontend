@inject IDataService DataService
@inject ILocalizationService L
@implements IDisposable

<section class="opensource" id="open-source">
    <div class="container">
        <div class="section-header text-center">
            <h2>@L["OpenSource.Title"]</h2>
            <p class="section-subtitle">@L["OpenSource.Subtitle"]</p>
        </div>

        <Slider Items="OpenSourceProjects" TItem="OpenSourceProject">
            <ItemTemplate Context="post">
                <article class="opensource-card">
                    <div class="opensource-header">
                        <div class="opensource-icon">@post.Icon</div>
                        <div class="opensource-title-section">
                            <h3>@post.Title</h3>
                            <div class="opensource-meta-inline">
                                <span class="opensource-status @post.StatusClass">@post.Status</span>
                                <span class="opensource-license">@L["OpenSource.License"] @post.License</span>
                            </div>
                        </div>
                    </div>

                    <p class="opensource-purpose">@post.Purpose</p>
                    <p class="opensource-description">@post.Description</p>

                    <div class="opensource-features">
                        <h4>@L["OpenSource.KeyFeatures"]</h4>
                        <ul>
                            @foreach (var feature in post.Features)
                            {
                                <li>@feature</li>
                            }
                        </ul>
                    </div>

                    <div class="opensource-use-cases">
                        <h4>@L["OpenSource.UseCases"]</h4>
                        <ul>
                            @foreach (var useCase in post.UseCases)
                            {
                                <li>@useCase</li>
                            }
                        </ul>
                    </div>

                    <div class="opensource-meta">
                        <span class="opensource-tech mono">@post.Technologies</span>
                    </div>

                    <p class="opensource-audience"><strong>@L["OpenSource.Audience"]</strong> @post.Audience</p>

                    <div class="opensource-links">
                        @if (!string.IsNullOrEmpty(post.GitHubUrl))
                        {
                            <a href="@post.GitHubUrl" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
                                @L["OpenSource.GitHub"]
                            </a>
                        }
                    </div>
                </article>
            </ItemTemplate>
        </Slider>
    </div>
</section>

@code {
    private List<OpenSourceProject> OpenSourceProjects = new();

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += OnLanguageChanged;
        OpenSourceProjects = await DataService.GetOpenSourceProjectsAsync();
    }

    private async void OnLanguageChanged()
    {
        OpenSourceProjects = await DataService.GetOpenSourceProjectsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}

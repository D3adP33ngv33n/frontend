@inject ILocalizationService L
@implements IDisposable

<footer class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-brand">
                <span class="logo-symbol mono">@AppConstants.LogoSymbol</span>
                <span class="logo-text mono">@AppConstants.CompanyName</span>
            </div>

            <div class="footer-legal mono">
                <span>&copy; @CurrentYear @AppConstants.CompanyName. @L["Footer.Rights"]</span>
            </div>

            <div class="footer-note">
                <span class="mono">@L["Footer.Tagline"]</span>
            </div>
        </div>
    </div>
</footer>

@code {
    private int CurrentYear => DateTime.Now.Year;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}

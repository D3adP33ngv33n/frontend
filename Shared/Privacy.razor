<section class="privacy" id="privacy">
    <div class="container">
        <div class="section-header">
            <h2>Privacy Policy</h2>
            <p class="section-subtitle">Discretion as a core operating principle</p>
        </div>

        <div class="privacy-content">
            <div class="privacy-text">
                <p class="mono">
                    We maintain absolute confidentiality across all engagements and client relationships.
                    Discretion is not a policy—it's embedded in our operational DNA.
                </p>
                <p>
                    Our clients entrust us with sensitive systems and critical infrastructure.
                    That responsibility shapes everything we do. Your engagement exists only between us.
                </p>
            </div>

            <div class="privacy-commitments">
                <h3>Our Commitments</h3>
                <ul class="commitments-list">
                    @foreach (var commitment in Commitments)
                    {
                        <li class="commitment-item mono">
                            <span class="commitment-marker">◉</span>
                            @commitment
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</section>

@code {
    private List<string> Commitments = new()
{
"Zero client disclosure without explicit consent",
"Complete project confidentiality maintained indefinitely",
"No third-party data sharing under any circumstances",
"Permanent non-disclosure as standard practice"
};
}
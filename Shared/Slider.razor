@typeparam TItem

<div class="slider-wrapper">
    <button class="slider-btn slider-btn-prev" @onclick="PrevSlide">
        <span class="slider-arrow">&#8249;</span>
    </button>

    <div class="slider-container">
        <div class="slider-viewport">
            <div class="slider-track @(disableTransition ? "no-transition" : "")"
                 style="transform: translateX(calc(-@trackIndex * (var(--card-width) + var(--card-gap))));">
                @* Clone all items at the beginning *@
                @foreach (var item in Items)
                {
                    <div class="slider-clone">
                        @ItemTemplate(item)
                    </div>
                }
                @* Actual items *@
                @foreach (var item in Items)
                {
                    @ItemTemplate(item)
                }
                @* Clone all items at the end *@
                @foreach (var item in Items)
                {
                    <div class="slider-clone">
                        @ItemTemplate(item)
                    </div>
                }
            </div>
        </div>
    </div>

    <button class="slider-btn slider-btn-next" @onclick="NextSlide">
        <span class="slider-arrow">&#8250;</span>
    </button>
</div>

<div class="slider-dots">
    @for (int i = 0; i < Items.Count; i++)
    {
        var index = i;
        <button class="slider-dot @(currentIndex == index ? "active" : "")" @onclick="() => GoToSlide(index)"></button>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IList<TItem> Items { get; set; } = new List<TItem>();

    [Parameter, EditorRequired]
    public RenderFragment<TItem> ItemTemplate { get; set; } = default!;

    private int currentIndex = 0;
    private int trackIndex => currentIndex + Items.Count; // +Items.Count to account for the clones at the beginning
    private bool disableTransition = false;

    protected override void OnInitialized()
    {
        currentIndex = 0;
    }

    private async Task NextSlide()
    {
        if (Items.Count == 0) return;

        currentIndex++;

        if (currentIndex >= Items.Count)
        {
            // We're now on the clone of the first item, wait for animation then jump
            await Task.Delay(400); // Match CSS transition duration
            disableTransition = true;
            currentIndex = 0;
            StateHasChanged();
            await Task.Delay(50); // Small delay for DOM update
            disableTransition = false;
            StateHasChanged();
        }
    }

    private async Task PrevSlide()
    {
        if (Items.Count == 0) return;

        currentIndex--;

        if (currentIndex < 0)
        {
            // We're now on the clone of the last item, wait for animation then jump
            await Task.Delay(400); // Match CSS transition duration
            disableTransition = true;
            currentIndex = Items.Count - 1;
            StateHasChanged();
            await Task.Delay(50); // Small delay for DOM update
            disableTransition = false;
            StateHasChanged();
        }
    }

    private void GoToSlide(int index)
    {
        currentIndex = index;
    }
}
